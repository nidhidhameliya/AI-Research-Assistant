# AI Research Assistant - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================
# REQUIRED
# =============================================================
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# =============================================================
# OPTIONAL
# =============================================================
# GitHub Personal Access Token (for private repo indexing)
GITHUB_TOKEN=ghp_your-github-token-here

# ChromaDB connection (used inside Docker)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Upload directory
UPLOAD_DIR=./uploads

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# App metadata and persistence
APP_NAME=AI Research Assistant
APP_DB_PATH=./vectorstore/app.db
JWT_SECRET_KEY=change-me-in-production

# Frontend API URL (change for production)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Research Assistant
